# 复制为 .env 后填入真实密钥：cp .env.example .env

# LangSmith
LANGSMITH_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=wealth-advisor-hybrid-agent

# 通义千问 / DashScope
DASHSCOPE_API_KEY=

# OpenAI（可选）
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1

CHAT_MODEL=gpt-4.1-mini

# LangFuse（langfuse_use 脚本需要，可选）
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
